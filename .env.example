# ─── AI Classification ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Slack ────────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Optional: POST /admin/test/slack-draft/:clientId with header x-webhook-test-secret
WEBHOOK_TEST_SECRET=long-random-string-for-local-slack-testing

# Optional: IANA timezone for displaying verified slot labels (default America/New_York)
# DEFAULT_BOOKING_TIMEZONE=America/Los_Angeles

# ─── Lead Enrichment (Lead Magic) ────────────────────────────────────
LEADMAGIC_API_KEY=your-leadmagic-api-key

# ─── Google Calendar OAuth (console.cloud.google.com) ────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Microsoft / Outlook OAuth (portal.azure.com) ────────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret

# ─── Server ───────────────────────────────────────────────────────────
# PORT and RAILWAY_PUBLIC_DOMAIN are set automatically by Railway.
# DATABASE_URL is injected by the Postgres plugin — do NOT set manually.

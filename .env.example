# ─── AI Classification ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# SMS cold outreach classifier (default gpt-4o-mini; override with OPENAI_SMS_INTENT_MODEL)
OPENAI_API_KEY=sk-your-openai-key
# Optional: intent classifier model
# OPENAI_SMS_INTENT_MODEL=gpt-4o-mini
# Inbound sentiment + opt-out (default gpt-4.1-nano)
# OPENAI_SENTIMENT_MODEL=gpt-4.1-nano

# Outbound SMS (SMSMobileAPI — smsmobileapi.com dashboard)
SMSMOBILEAPI_KEY=your-smsmobileapi-api-key

# Optional per-client carrier throttle (dashboard: Edit client → Minimum gap between outbound texts ms).
# Stored in DB column clients.sms_min_gap_between_texts_ms — no env var required.

# ─── Supabase — use a dedicated project for this app (not your CRM DB); see supabase/README.md
SUPABASE_URL=https://YOUR_REPLY_HANDLER_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ─── Google Sheets (service account JSON — optional legacy / enrichment)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Slack ────────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Optional: POST /admin/test/slack-draft/:clientId with header x-webhook-test-secret
WEBHOOK_TEST_SECRET=long-random-string-for-local-slack-testing
# Optional: if set, SMS dashboard mutations require matching header x-dashboard-secret (advanced lock-down)
# DASHBOARD_ACTION_SECRET=

# Optional: IANA timezone for displaying verified slot labels (default America/New_York)
# DEFAULT_BOOKING_TIMEZONE=America/Los_Angeles

# ─── Lead Enrichment (Lead Magic) ────────────────────────────────────
LEADMAGIC_API_KEY=your-leadmagic-api-key

# ─── Google OAuth (Calendar + Gmail watcher share same client id/secret) ─
# Enable Gmail API in Google Cloud; redirect URI must include /auth/gmail/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Microsoft / Outlook OAuth (portal.azure.com) ────────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret

# ─── Server ───────────────────────────────────────────────────────────
# PORT and RAILWAY_PUBLIC_DOMAIN are set automatically by Railway.
# DATABASE_URL is injected by the Postgres plugin — do NOT set manually.
